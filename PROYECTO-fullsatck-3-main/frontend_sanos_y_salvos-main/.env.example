# Frontend Environment - Sanos y Salvos

# URLs DIRECTAS a microservicios (auth/user mientras BFF sea stub)
VITE_AUTH_SERVICE_URL=http://localhost:8001
VITE_USER_SERVICE_URL=http://localhost:8002

# URLs VIA BFF (preferido para todos los nuevos endpoints)
VITE_BFF_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000/api
VITE_GEO_SERVICE_URL=http://localhost:5000/api

# WebSocket (conexion directa para minimizar latencia)
VITE_CHAT_WS_URL=ws://localhost:8004

# Mapbox token publico (requerido para el mapa)
VITE_MAPBOX_TOKEN=pk.xxx

# Branding
VITE_APP_NAME=Sanos y Salvos
VITE_APP_VERSION=1.0.0

# NOTA: Auth y User van DIRECTOS a sus microservicios mientras el BFF
# tenga stubs falsos en backend/routes/auth.js. Los demas van via BFF.
