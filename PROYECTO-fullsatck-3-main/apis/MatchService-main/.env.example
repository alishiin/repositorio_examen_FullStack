# MatchService - Variables de entorno
# Copia este archivo a `.env` y rellena con tus valores reales.
# El archivo `.env` esta en .gitignore — NUNCA lo commitees.

# API Key de Google Gemini (https://aistudio.google.com/apikey)
# Si esta vacia, MatchService funciona en modo degradado (sin llamadas reales a IA).
GEMINI_API_KEY=tu-key-de-google-gemini-aqui

# Django
DJANGO_SECRET_KEY=change-me-in-prod
DEBUG=True
